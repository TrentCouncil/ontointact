@prefix : <http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#> .

<http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30> rdf:type owl:Ontology ;
                                                                           owl:versionIRI <http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30/1.0.0> ;
                                                                           <http://purl.org/dc/terms/creator> "INT-ACT UÉvora Team" ;
                                                                           <http://purl.org/dc/terms/license> <https://creativecommons.org/licenses/by/4.0/> ;
                                                                           rdfs:comment "This ontology reuses and integrates the SKOS (Simple Knowledge Organization System) vocabulary for the organisation of domain-specific concepts, and builds upon the CIDOC Conceptual Reference Model (CRM) for the representation of cultural heritage entities and events." .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.org/dc/terms/contributor
<http://purl.org/dc/terms/contributor> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/creator
<http://purl.org/dc/terms/creator> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/description
<http://purl.org/dc/terms/description> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/license
<http://purl.org/dc/terms/license> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/title
<http://purl.org/dc/terms/title> rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#altLabel
<http://www.w3.org/2004/02/skos/core#altLabel> rdf:type owl:AnnotationProperty ;
                                               rdfs:comment "The range of skos:altLabel is the class of RDF plain literals."@en ,
                                                            "skos:prefLabel, skos:altLabel and skos:hiddenLabel are pairwise disjoint properties."@en ;
                                               rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
                                               <http://www.w3.org/2004/02/skos/core#definition> "An alternative lexical label for a resource."@en ;
                                               <http://www.w3.org/2004/02/skos/core#example> "Acronyms, abbreviations, spelling variants, and irregular plural/singular forms may be included among the alternative labels for a concept. Mis-spelled terms are normally included as hidden labels (see skos:hiddenLabel)."@en .


###  http://www.w3.org/2004/02/skos/core#changeNote
<http://www.w3.org/2004/02/skos/core#changeNote> rdf:type owl:AnnotationProperty ;
                                                 rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
                                                 <http://www.w3.org/2004/02/skos/core#definition> "A note about a modification to a concept."@en ;
                                                 rdfs:subPropertyOf <http://www.w3.org/2004/02/skos/core#note> .


###  http://www.w3.org/2004/02/skos/core#definition
<http://www.w3.org/2004/02/skos/core#definition> rdf:type owl:AnnotationProperty ;
                                                 rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
                                                 <http://www.w3.org/2004/02/skos/core#definition> "A statement or formal explanation of the meaning of a concept."@en ;
                                                 rdfs:subPropertyOf <http://www.w3.org/2004/02/skos/core#note> .


###  http://www.w3.org/2004/02/skos/core#editorialNote
<http://www.w3.org/2004/02/skos/core#editorialNote> rdf:type owl:AnnotationProperty ;
                                                    rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
                                                    <http://www.w3.org/2004/02/skos/core#definition> "A note for an editor, translator or maintainer of the vocabulary."@en ;
                                                    rdfs:subPropertyOf <http://www.w3.org/2004/02/skos/core#note> .


###  http://www.w3.org/2004/02/skos/core#example
<http://www.w3.org/2004/02/skos/core#example> rdf:type owl:AnnotationProperty ;
                                              rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
                                              <http://www.w3.org/2004/02/skos/core#definition> "An example of the use of a concept."@en ;
                                              rdfs:subPropertyOf <http://www.w3.org/2004/02/skos/core#note> .


###  http://www.w3.org/2004/02/skos/core#hiddenLabel
<http://www.w3.org/2004/02/skos/core#hiddenLabel> rdf:type owl:AnnotationProperty ;
                                                  rdfs:comment "The range of skos:hiddenLabel is the class of RDF plain literals."@en ,
                                                               "skos:prefLabel, skos:altLabel and skos:hiddenLabel are pairwise disjoint properties."@en ;
                                                  rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
                                                  <http://www.w3.org/2004/02/skos/core#definition> "A lexical label for a resource that should be hidden when generating visual displays of the resource, but should still be accessible to free text search operations."@en .


###  http://www.w3.org/2004/02/skos/core#historyNote
<http://www.w3.org/2004/02/skos/core#historyNote> rdf:type owl:AnnotationProperty ;
                                                  rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
                                                  <http://www.w3.org/2004/02/skos/core#definition> "A note about the past state/use/meaning of a concept."@en ;
                                                  rdfs:subPropertyOf <http://www.w3.org/2004/02/skos/core#note> .


###  http://www.w3.org/2004/02/skos/core#note
<http://www.w3.org/2004/02/skos/core#note> rdf:type owl:AnnotationProperty ;
                                           rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
                                           <http://www.w3.org/2004/02/skos/core#definition> "A general note, for any purpose."@en ;
                                           <http://www.w3.org/2004/02/skos/core#scopeNote> "This property may be used directly, or as a super-property for more specific note types."@en .


###  http://www.w3.org/2004/02/skos/core#prefLabel
<http://www.w3.org/2004/02/skos/core#prefLabel> rdf:type owl:AnnotationProperty ;
                                                rdfs:comment "A resource has no more than one value of skos:prefLabel per language tag, and no more than one value of skos:prefLabel without language tag."@en ,
                                                             "The range of skos:prefLabel is the class of RDF plain literals."@en ,
                                                             """skos:prefLabel, skos:altLabel and skos:hiddenLabel are pairwise
      disjoint properties."""@en ;
                                                rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
                                                <http://www.w3.org/2004/02/skos/core#definition> "The preferred lexical label for a resource, in a given language."@en .


###  http://www.w3.org/2004/02/skos/core#scopeNote
<http://www.w3.org/2004/02/skos/core#scopeNote> rdf:type owl:AnnotationProperty ;
                                                rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
                                                <http://www.w3.org/2004/02/skos/core#definition> "A note that helps to clarify the meaning and/or the use of a concept."@en ;
                                                rdfs:subPropertyOf <http://www.w3.org/2004/02/skos/core#note> .


#################################################################
#    Object Properties
#################################################################

###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#P129_isAbout
:P129_isAbout rdf:type owl:ObjectProperty ;
              rdfs:domain :E89_Propositional_Object ;
              rdfs:range :E1_CRM_Entity ;
              rdfs:label "is About"@en .


###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#P130_shows_features_of
:P130_shows_features_of rdf:type owl:ObjectProperty ;
                        rdfs:domain :E70_Thing ;
                        rdfs:range :E70_Thing ;
                        rdfs:label "shows features of"@en .


###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#P14_carriedOutBy
:P14_carriedOutBy rdf:type owl:ObjectProperty ;
                  rdfs:domain :E7_Activity ;
                  rdfs:range :E39_Actor ;
                  rdfs:label "carried Out By"@en .


###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#P165_incorporates
:P165_incorporates rdf:type owl:ObjectProperty ;
                   rdfs:domain :E89_Propositional_Object ;
                   rdfs:range :E90_Symbolic_Object ;
                   rdfs:label "incorporates"@en .


###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#P198_holds_or_supports
:P198_holds_or_supports rdf:type owl:ObjectProperty ;
                        rdfs:domain :E18_Physical_Thing ;
                        rdfs:range :E18_Physical_Thing ;
                        rdfs:label "holds or supports"@en .


###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#P46_IsComposedOf
:P46_IsComposedOf rdf:type owl:ObjectProperty ;
                  rdfs:domain :E18_Physical_Thing ;
                  rdfs:range :E18_Physical_Thing ;
                  rdfs:label "Is Composed Of"@en .


###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#P4_hasTimeSpan
:P4_hasTimeSpan rdf:type owl:ObjectProperty ;
                rdfs:domain :E2_Temporal_Entity ;
                rdfs:range :E52_TimeSpan ;
                rdfs:label "has Time Span"@en .


###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#P53_has_former_or_current_location
:P53_has_former_or_current_location rdf:type owl:ObjectProperty ;
                                    rdfs:domain :E18_Physical_Thing ;
                                    rdfs:range :E53_Place ;
                                    rdfs:label "has former or current location"@en .


###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#P89_falls_within
:P89_falls_within rdf:type owl:ObjectProperty ;
                  rdfs:domain :E53_Place ;
                  rdfs:range :E53_Place ;
                  rdfs:label "falls within"@en .


###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#P8_took_place_on_or_within
:P8_took_place_on_or_within rdf:type owl:ObjectProperty ;
                            rdfs:domain :E4_Period ;
                            rdfs:range :E18_Physical_Thing ;
                            rdfs:label "took place on or within"@en .


###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#hasArtisticTimeSpan
:hasArtisticTimeSpan rdf:type owl:ObjectProperty ;
                     rdfs:subPropertyOf :P4_hasTimeSpan ;
                     rdfs:domain :Romanticism ;
                     rdfs:range :E52_TimeSpan ;
                     rdfs:label "has Artistic Time Span"@en .


###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#hasClimate
:hasClimate rdf:type owl:ObjectProperty ;
            rdfs:subPropertyOf :P130_shows_features_of ;
            rdfs:domain :E53_Place ;
            rdfs:range :Climate ;
            rdfs:label "has Climate"@en .


###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#hasConstructionTimeSpan
:hasConstructionTimeSpan rdf:type owl:ObjectProperty ;
                         rdfs:subPropertyOf :P4_hasTimeSpan ;
                         rdfs:domain :Construction ;
                         rdfs:range :E52_TimeSpan ;
                         rdfs:label "has Construction Time Span"@en .


###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#hasEngravings
:hasEngravings rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf :P130_shows_features_of ;
               rdfs:domain :Menhir ;
               rdfs:range :Engravings ;
               rdfs:label "has Engravings"@en .


###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#hasExcavationTimeSpan
:hasExcavationTimeSpan rdf:type owl:ObjectProperty ;
                       rdfs:subPropertyOf :P4_hasTimeSpan ;
                       rdfs:domain :Excavation ;
                       rdfs:range :E52_TimeSpan ;
                       rdfs:label "has Excavation Time Span"@en .


###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#hasFormationTimeSpan
:hasFormationTimeSpan rdf:type owl:ObjectProperty ;
                      rdfs:subPropertyOf :P4_hasTimeSpan ;
                      rdfs:domain :Formation ;
                      rdfs:range :E52_TimeSpan ;
                      rdfs:label "has Formation Time Span"@en .


###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#hasIdentificationTimeSpan
:hasIdentificationTimeSpan rdf:type owl:ObjectProperty ;
                           rdfs:subPropertyOf :P4_hasTimeSpan ;
                           rdfs:domain :Identification ;
                           rdfs:label "has Identification Time Span"@en .


###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#hasMegalithicComponents
:hasMegalithicComponents rdf:type owl:ObjectProperty ;
                         rdfs:subPropertyOf :P46_IsComposedOf ;
                         rdfs:domain :MegalithicMonument ;
                         rdfs:range :Menhir ;
                         rdfs:label "has Megalithic Components"@en .


###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#hasTypicalLandscape
:hasTypicalLandscape rdf:type owl:ObjectProperty ;
                     rdfs:subPropertyOf :P130_shows_features_of ;
                     rdfs:domain :E53_Place ;
                     rdfs:range :Landscape ;
                     rdfs:label "has Typical Landscape"@en .


###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#hasUsageTimeSpan
:hasUsageTimeSpan rdf:type owl:ObjectProperty ;
                  rdfs:subPropertyOf :P4_hasTimeSpan ;
                  rdfs:domain :OcupationOrUsage ;
                  rdfs:range :E52_TimeSpan ;
                  rdfs:label "has Usage Time Span"@en .


###  http://www.w3.org/2004/02/skos/core#broadMatch
<http://www.w3.org/2004/02/skos/core#broadMatch> rdf:type owl:ObjectProperty ;
                                                 rdfs:subPropertyOf <http://www.w3.org/2004/02/skos/core#broader> ,
                                                                    <http://www.w3.org/2004/02/skos/core#mappingRelation> ;
                                                 owl:inverseOf <http://www.w3.org/2004/02/skos/core#narrowMatch> ;
                                                 rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
                                                 <http://www.w3.org/2004/02/skos/core#definition> "skos:broadMatch is used to state a hierarchical mapping link between two conceptual resources in different concept schemes."@en .


###  http://www.w3.org/2004/02/skos/core#broader
<http://www.w3.org/2004/02/skos/core#broader> rdf:type owl:ObjectProperty ;
                                              rdfs:subPropertyOf <http://www.w3.org/2004/02/skos/core#broaderTransitive> ;
                                              owl:inverseOf <http://www.w3.org/2004/02/skos/core#narrower> ;
                                              rdfs:comment "Broader concepts are typically rendered as parents in a concept hierarchy (tree)."@en ;
                                              rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
                                              <http://www.w3.org/2004/02/skos/core#definition> "Relates a concept to a concept that is more general in meaning."@en ;
                                              <http://www.w3.org/2004/02/skos/core#scopeNote> "By convention, skos:broader is only used to assert an immediate (i.e. direct) hierarchical link between two conceptual resources."@en .


###  http://www.w3.org/2004/02/skos/core#broaderTransitive
<http://www.w3.org/2004/02/skos/core#broaderTransitive> rdf:type owl:ObjectProperty ;
                                                        rdfs:subPropertyOf <http://www.w3.org/2004/02/skos/core#semanticRelation> ;
                                                        owl:inverseOf <http://www.w3.org/2004/02/skos/core#narrowerTransitive> ;
                                                        rdf:type owl:TransitiveProperty ;
                                                        rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
                                                        <http://www.w3.org/2004/02/skos/core#definition> "skos:broaderTransitive is a transitive superproperty of skos:broader." ;
                                                        <http://www.w3.org/2004/02/skos/core#scopeNote> "By convention, skos:broaderTransitive is not used to make assertions. Rather, the properties can be used to draw inferences about the transitive closure of the hierarchical relation, which is useful e.g. when implementing a simple query expansion algorithm in a search application."@en .


###  http://www.w3.org/2004/02/skos/core#closeMatch
<http://www.w3.org/2004/02/skos/core#closeMatch> rdf:type owl:ObjectProperty ;
                                                 rdfs:subPropertyOf <http://www.w3.org/2004/02/skos/core#mappingRelation> ;
                                                 rdf:type owl:SymmetricProperty ;
                                                 rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
                                                 <http://www.w3.org/2004/02/skos/core#definition> "skos:closeMatch is used to link two concepts that are sufficiently similar that they can be used interchangeably in some information retrieval applications. In order to avoid the possibility of \"compound errors\" when combining mappings across more than two concept schemes, skos:closeMatch is not declared to be a transitive property."@en .


###  http://www.w3.org/2004/02/skos/core#exactMatch
<http://www.w3.org/2004/02/skos/core#exactMatch> rdf:type owl:ObjectProperty ;
                                                 rdfs:subPropertyOf <http://www.w3.org/2004/02/skos/core#closeMatch> ;
                                                 rdf:type owl:SymmetricProperty ,
                                                          owl:TransitiveProperty ;
                                                 rdfs:comment "skos:exactMatch is disjoint with each of the properties skos:broadMatch and skos:relatedMatch."@en ;
                                                 rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
                                                 <http://www.w3.org/2004/02/skos/core#definition> "skos:exactMatch is used to link two concepts, indicating a high degree of confidence that the concepts can be used interchangeably across a wide range of information retrieval applications. skos:exactMatch is a transitive property, and is a sub-property of skos:closeMatch."@en .


###  http://www.w3.org/2004/02/skos/core#hasTopConcept
<http://www.w3.org/2004/02/skos/core#hasTopConcept> rdf:type owl:ObjectProperty ;
                                                    owl:inverseOf <http://www.w3.org/2004/02/skos/core#topConceptOf> ;
                                                    rdfs:domain <http://www.w3.org/2004/02/skos/core#ConceptScheme> ;
                                                    rdfs:range <http://www.w3.org/2004/02/skos/core#Concept> ;
                                                    rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
                                                    <http://www.w3.org/2004/02/skos/core#definition> "Relates, by convention, a concept scheme to a concept which is topmost in the broader/narrower concept hierarchies for that scheme, providing an entry point to these hierarchies."@en .


###  http://www.w3.org/2004/02/skos/core#inScheme
<http://www.w3.org/2004/02/skos/core#inScheme> rdf:type owl:ObjectProperty ;
                                               rdfs:range <http://www.w3.org/2004/02/skos/core#ConceptScheme> ;
                                               rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
                                               <http://www.w3.org/2004/02/skos/core#definition> "Relates a resource (for example a concept) to a concept scheme in which it is included."@en ;
                                               <http://www.w3.org/2004/02/skos/core#scopeNote> "A concept may be a member of more than one concept scheme."@en .


###  http://www.w3.org/2004/02/skos/core#mappingRelation
<http://www.w3.org/2004/02/skos/core#mappingRelation> rdf:type owl:ObjectProperty ;
                                                      rdfs:subPropertyOf <http://www.w3.org/2004/02/skos/core#semanticRelation> ;
                                                      rdfs:comment "These concept mapping relations mirror semantic relations, and the data model defined below is similar (with the exception of skos:exactMatch) to the data model defined for semantic relations. A distinct vocabulary is provided for concept mapping relations, to provide a convenient way to differentiate links within a concept scheme from links between concept schemes. However, this pattern of usage is not a formal requirement of the SKOS data model, and relies on informal definitions of best practice."@en ;
                                                      rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
                                                      <http://www.w3.org/2004/02/skos/core#definition> "Relates two concepts coming, by convention, from different schemes, and that have comparable meanings"@en .


###  http://www.w3.org/2004/02/skos/core#member
<http://www.w3.org/2004/02/skos/core#member> rdf:type owl:ObjectProperty ;
                                             rdfs:domain <http://www.w3.org/2004/02/skos/core#Collection> ;
                                             rdfs:range [ rdf:type owl:Class ;
                                                          owl:unionOf ( <http://www.w3.org/2004/02/skos/core#Collection>
                                                                        <http://www.w3.org/2004/02/skos/core#Concept>
                                                                      )
                                                        ] ;
                                             rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
                                             <http://www.w3.org/2004/02/skos/core#definition> "Relates a collection to one of its members."@en .


###  http://www.w3.org/2004/02/skos/core#memberList
<http://www.w3.org/2004/02/skos/core#memberList> rdf:type owl:ObjectProperty ,
                                                          owl:FunctionalProperty ;
                                                 rdfs:domain <http://www.w3.org/2004/02/skos/core#OrderedCollection> ;
                                                 rdfs:range rdf:List ;
                                                 rdfs:comment """For any resource, every item in the list given as the value of the
      skos:memberList property is also a value of the skos:member property."""@en ;
                                                 rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
                                                 <http://www.w3.org/2004/02/skos/core#definition> "Relates an ordered collection to the RDF list containing its members."@en .


###  http://www.w3.org/2004/02/skos/core#narrowMatch
<http://www.w3.org/2004/02/skos/core#narrowMatch> rdf:type owl:ObjectProperty ;
                                                  rdfs:subPropertyOf <http://www.w3.org/2004/02/skos/core#mappingRelation> ,
                                                                     <http://www.w3.org/2004/02/skos/core#narrower> ;
                                                  rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
                                                  <http://www.w3.org/2004/02/skos/core#definition> "skos:narrowMatch is used to state a hierarchical mapping link between two conceptual resources in different concept schemes."@en .


###  http://www.w3.org/2004/02/skos/core#narrower
<http://www.w3.org/2004/02/skos/core#narrower> rdf:type owl:ObjectProperty ;
                                               rdfs:subPropertyOf <http://www.w3.org/2004/02/skos/core#narrowerTransitive> ;
                                               rdfs:comment "Narrower concepts are typically rendered as children in a concept hierarchy (tree)."@en ;
                                               rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
                                               <http://www.w3.org/2004/02/skos/core#definition> "Relates a concept to a concept that is more specific in meaning."@en ;
                                               <http://www.w3.org/2004/02/skos/core#scopeNote> "By convention, skos:broader is only used to assert an immediate (i.e. direct) hierarchical link between two conceptual resources."@en .


###  http://www.w3.org/2004/02/skos/core#narrowerTransitive
<http://www.w3.org/2004/02/skos/core#narrowerTransitive> rdf:type owl:ObjectProperty ;
                                                         rdfs:subPropertyOf <http://www.w3.org/2004/02/skos/core#semanticRelation> ;
                                                         rdf:type owl:TransitiveProperty ;
                                                         rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
                                                         <http://www.w3.org/2004/02/skos/core#definition> "skos:narrowerTransitive is a transitive superproperty of skos:narrower." ;
                                                         <http://www.w3.org/2004/02/skos/core#scopeNote> "By convention, skos:narrowerTransitive is not used to make assertions. Rather, the properties can be used to draw inferences about the transitive closure of the hierarchical relation, which is useful e.g. when implementing a simple query expansion algorithm in a search application."@en .


###  http://www.w3.org/2004/02/skos/core#related
<http://www.w3.org/2004/02/skos/core#related> rdf:type owl:ObjectProperty ;
                                              rdfs:subPropertyOf <http://www.w3.org/2004/02/skos/core#semanticRelation> ;
                                              rdf:type owl:SymmetricProperty ;
                                              rdfs:comment "skos:related is disjoint with skos:broaderTransitive"@en ;
                                              rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
                                              <http://www.w3.org/2004/02/skos/core#definition> "Relates a concept to a concept with which there is an associative semantic relationship."@en .


###  http://www.w3.org/2004/02/skos/core#relatedMatch
<http://www.w3.org/2004/02/skos/core#relatedMatch> rdf:type owl:ObjectProperty ;
                                                   rdfs:subPropertyOf <http://www.w3.org/2004/02/skos/core#mappingRelation> ,
                                                                      <http://www.w3.org/2004/02/skos/core#related> ;
                                                   rdf:type owl:SymmetricProperty ;
                                                   rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
                                                   <http://www.w3.org/2004/02/skos/core#definition> "skos:relatedMatch is used to state an associative mapping link between two conceptual resources in different concept schemes."@en .


###  http://www.w3.org/2004/02/skos/core#semanticRelation
<http://www.w3.org/2004/02/skos/core#semanticRelation> rdf:type owl:ObjectProperty ;
                                                       rdfs:domain <http://www.w3.org/2004/02/skos/core#Concept> ;
                                                       rdfs:range <http://www.w3.org/2004/02/skos/core#Concept> ;
                                                       rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
                                                       <http://www.w3.org/2004/02/skos/core#definition> "Links a concept to a concept related by meaning."@en ;
                                                       <http://www.w3.org/2004/02/skos/core#scopeNote> "This property should not be used directly, but as a super-property for all properties denoting a relationship of meaning between concepts."@en .


###  http://www.w3.org/2004/02/skos/core#topConceptOf
<http://www.w3.org/2004/02/skos/core#topConceptOf> rdf:type owl:ObjectProperty ;
                                                   rdfs:subPropertyOf <http://www.w3.org/2004/02/skos/core#inScheme> ;
                                                   rdfs:domain <http://www.w3.org/2004/02/skos/core#Concept> ;
                                                   rdfs:range <http://www.w3.org/2004/02/skos/core#ConceptScheme> ;
                                                   rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
                                                   <http://www.w3.org/2004/02/skos/core#definition> "Relates a concept to the concept scheme that it is a top level concept of."@en .


#################################################################
#    Data properties
#################################################################

###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Link
:Link rdf:type owl:DatatypeProperty ;
      rdfs:subPropertyOf owl:topDataProperty ;
      rdfs:domain :Audio ,
                  :Image ,
                  :Narrative ;
      rdfs:range xsd:anyURI ;
      rdfs:label "Link"@en .


###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#format
:format rdf:type owl:DatatypeProperty ;
        rdfs:subPropertyOf owl:topDataProperty ;
        rdfs:domain :MegalithicMonument ;
        rdfs:range xsd:string ;
        rdfs:label "format"@en .


###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#heightMeters
:heightMeters rdf:type owl:DatatypeProperty ;
              rdfs:subPropertyOf owl:topDataProperty ;
              rdfs:domain :Menhir ;
              rdfs:range xsd:decimal ;
              rdfs:label "height Meters"@en .


###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#rockType
:rockType rdf:type owl:DatatypeProperty ;
          rdfs:subPropertyOf owl:topDataProperty ;
          rdfs:domain :MegalithicMonument ;
          rdfs:range xsd:string ;
          rdfs:label "rock Type"@en .


###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#usagetypeArtefacts
:usagetypeArtefacts rdf:type owl:DatatypeProperty ;
                    rdfs:subPropertyOf owl:topDataProperty ;
                    rdfs:domain :ArchaeologicalArtefact ;
                    rdfs:range xsd:string ;
                    rdfs:label "usagetype Artefacts"@en .


###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#usagetypeMegalithism
:usagetypeMegalithism rdf:type owl:DatatypeProperty ;
                      rdfs:subPropertyOf owl:topDataProperty ;
                      rdfs:domain :MegalithicSite ;
                      rdfs:range xsd:string ;
                      rdfs:label "usagetype Megalithism"@en .


###  http://www.w3.org/2004/02/skos/core#notation
<http://www.w3.org/2004/02/skos/core#notation> rdf:type owl:DatatypeProperty ;
                                               rdfs:subPropertyOf owl:topDataProperty ;
                                               rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
                                               <http://www.w3.org/2004/02/skos/core#definition> "A notation, also known as classification code, is a string of characters such as \"T58.5\" or \"303.4833\" used to uniquely identify a concept within the scope of a given concept scheme."@en ;
                                               <http://www.w3.org/2004/02/skos/core#scopeNote> "By convention, skos:notation is used with a typed literal in the object position of the triple."@en .


#################################################################
#    Classes
#################################################################

###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#App
:App rdf:type owl:Class ;
     rdfs:subClassOf :E31_Document ;
     rdfs:comment "A software application designed to guide or assist users, often in cultural or educational contexts" ;
     rdfs:label "App"@en .


###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#ArchaeologicalArtefact
:ArchaeologicalArtefact rdf:type owl:Class ;
                        rdfs:subClassOf :E19_Physical_Object ;
                        rdfs:comment "Artefacts found in an archaeological site." ;
                        rdfs:label "Archaeological Artefact"@en .


###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#ArchaeologicalMonument
:ArchaeologicalMonument rdf:type owl:Class ;
                        rdfs:subClassOf :CulturalHeritageMonument ;
                        rdfs:comment "A monument that preserves traces of human occupation" ;
                        rdfs:label "Archaeological Monument"@en .


###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#ArchaeologicalSite
:ArchaeologicalSite rdf:type owl:Class ;
                    rdfs:subClassOf :E27_Site ;
                    rdfs:comment "The area where traces of human occupation have been found." ;
                    rdfs:label "Archaeological Site"@en .


###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Archaeologist
:Archaeologist rdf:type owl:Class ;
               rdfs:subClassOf :E21_Person ;
               rdfs:comment "A professional whose expertise involves both on-site and off-site study of past human societies." ;
               rdfs:label "Archaeologist"@en .


###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Arrowhead
:Arrowhead rdf:type owl:Class ;
           rdfs:subClassOf :ArchaeologicalArtefact ;
           rdfs:comment "The tip of an arrow." ;
           rdfs:label "Arrowhead"@en .


###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Artist
:Artist rdf:type owl:Class ;
        rdfs:subClassOf :E21_Person ;
        rdfs:comment "An individual whose creative work reflects or engages with the heritage site" ;
        rdfs:label "Artist"@en .


###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Audio
:Audio rdf:type owl:Class ;
       rdfs:subClassOf :E31_Document ;
       rdfs:comment "Audio files" ;
       rdfs:label "Audio"@en .


###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Beaker
:Beaker rdf:type owl:Class ;
        rdfs:subClassOf :ArchaeologicalArtefact ;
        rdfs:comment "A ceramic drinking or storage vessel typical of Late Neolithic/Bronze Age." ;
        rdfs:label "Beaker"@en .


###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#BirdSounds
:BirdSounds rdf:type owl:Class ;
            rdfs:subClassOf :NaturalSoundscape ;
            rdfs:comment "Sounds of birds chirping." ;
            rdfs:label "Bird Sounds"@en .


###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#BronzeAge
:BronzeAge rdf:type owl:Class ;
           rdfs:subClassOf :E4_Period ;
           owl:disjointWith :Neolithic ;
           rdfs:comment "A specific and transitional period between prehistory and protohistory" ;
           rdfs:label "Bronze Age"@en .


###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Cave
:Cave rdf:type owl:Class ;
      rdfs:subClassOf :NaturalHeritageSite ;
      rdfs:comment "A natural underground space typically formed by the weathering of rock." ;
      rdfs:label "Cave"@en .


###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Climate
:Climate rdf:type owl:Class ;
         rdfs:subClassOf :E26_Physical_Feature ;
         rdfs:comment "A feature regarding weather conditions." ;
         rdfs:label "Climate"@en .


###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Construction
:Construction rdf:type owl:Class ;
              rdfs:subClassOf :E7_Activity ;
              rdfs:comment "The construction of the archaeological site." ;
              rdfs:label "Construction"@en .


###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Coordinates
:Coordinates rdf:type owl:Class ;
             rdfs:subClassOf :E94_Space_Primitive ;
             rdfs:comment "A specific location in space" ;
             rdfs:label "Coordinates"@en .


###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#CulturalHeritageMonument
:CulturalHeritageMonument rdf:type owl:Class ;
                          rdfs:subClassOf :E24_Physical_Human-Made_Thing ;
                          rdfs:label "Cultural Heritage Monument"@en .


###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#CulturalHeritageSite
:CulturalHeritageSite rdf:type owl:Class ;
                      rdfs:subClassOf :E27_Site ;
                      rdfs:comment "A place of importance recognised for its historical and cultural value" ;
                      rdfs:label "Cultural Heritage Site"@en .


###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#CulturalLandscape
:CulturalLandscape rdf:type owl:Class ;
                   rdfs:subClassOf :Landscape ;
                   rdfs:comment "A landscape containing features made by humans. It can be protected as a cultural heritage site." ;
                   rdfs:label "Cultural Landscape"@en .


###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#CulturalLandscapeSite
:CulturalLandscapeSite rdf:type owl:Class ;
                       rdfs:subClassOf :E27_Site ;
                       rdfs:comment "A landscape that has been shaped or symbolically interpreted through cultural practices, beliefs, or artistic representation." ;
                       rdfs:label "Cultural Landscape Site"@en .


###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Demonstrator
:Demonstrator rdf:type owl:Class ;
              rdfs:subClassOf :E71_Human-Made_Thing ;
              rdfs:comment "A prototype or tool created to showcase a concept or functionality" ;
              rdfs:label "Demonstrator"@en .


###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#District
:District rdf:type owl:Class ;
          rdfs:subClassOf :E53_Place ;
          rdfs:comment "A subdivision of a region that can encompass multiple municipalities within boundaries" ;
          rdfs:label "District"@en .


###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#E18_Physical_Thing
:E18_Physical_Thing rdf:type owl:Class ;
                    rdfs:subClassOf :E70_Thing ;
                    rdfs:label "E18 Physical Thing"@en .


###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#E19_Physical_Object
:E19_Physical_Object rdf:type owl:Class ;
                     rdfs:subClassOf :E18_Physical_Thing ;
                     rdfs:label "E19 Physical Object"@en .


###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#E1_CRM_Entity
:E1_CRM_Entity rdf:type owl:Class ;
               rdfs:label "E1 CRM Entity"@en .


###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#E21_Person
:E21_Person rdf:type owl:Class ;
            rdfs:subClassOf :E39_Actor ;
            rdfs:label "E21 Person"@en .


###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#E24_Physical_Human-Made_Thing
:E24_Physical_Human-Made_Thing rdf:type owl:Class ;
                               rdfs:subClassOf :E18_Physical_Thing ,
                                               :E71_Human-Made_Thing ;
                               rdfs:label "E24 Physical Human Made Thing"@en .


###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#E26_Physical_Feature
:E26_Physical_Feature rdf:type owl:Class ;
                      rdfs:subClassOf :E18_Physical_Thing ;
                      rdfs:label "E26 Physical Feature"@en .


###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#E27_Site
:E27_Site rdf:type owl:Class ;
          rdfs:subClassOf :E26_Physical_Feature ;
          rdfs:comment "This class comprises pieces of land or sea floor. In contrast to the purely geometric notion of E53 Place, this class describes constellations of matter on the surface of the Earth or other celestial body, which can be represented by photographs, paintings and maps. Instances of E27 Site are composed of relatively immobile material items and features in a particular configuration at a particular location." ;
          rdfs:label "Site"@en .


###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#E2_Temporal_Entity
:E2_Temporal_Entity rdf:type owl:Class ;
                    rdfs:subClassOf :E1_CRM_Entity ;
                    rdfs:label "E2 Temporal Entity"@en .


###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#E31_Document
:E31_Document rdf:type owl:Class ;
              rdfs:subClassOf :E73_Information_Object ;
              rdfs:label "E31 Document"@en .


###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#E33_Linguistic_Object
:E33_Linguistic_Object rdf:type owl:Class ;
                       rdfs:subClassOf :E73_Information_Object ;
                       rdfs:label "E33 Linguistic Object"@en .


###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#E39_Actor
:E39_Actor rdf:type owl:Class ;
           rdfs:subClassOf :E1_CRM_Entity ;
           rdfs:label "E39 Actor"@en .


###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#E4_Period
:E4_Period rdf:type owl:Class ;
           rdfs:subClassOf :E2_Temporal_Entity ;
           rdfs:label "E4 Period"@en .


###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#E52_TimeSpan
:E52_TimeSpan rdf:type owl:Class ;
              rdfs:subClassOf :E1_CRM_Entity ;
              rdfs:label "E52 Time Span"@en .


###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#E53_Place
:E53_Place rdf:type owl:Class ;
           rdfs:subClassOf :E1_CRM_Entity ;
           rdfs:label "E53 Place"@en .


###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#E55_Type
:E55_Type rdf:type owl:Class ;
          rdfs:subClassOf :E1_CRM_Entity ;
          rdfs:label "E55 Type"@en .


###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#E70_Thing
:E70_Thing rdf:type owl:Class ;
           rdfs:subClassOf :E1_CRM_Entity ;
           rdfs:label "E70 Thing"@en .


###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#E71_Human-Made_Thing
:E71_Human-Made_Thing rdf:type owl:Class ;
                      rdfs:subClassOf :E70_Thing ;
                      rdfs:label "E71 Human Made Thing"@en .


###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#E73_Information_Object
:E73_Information_Object rdf:type owl:Class ;
                        rdfs:subClassOf :E90_Symbolic_Object ;
                        rdfs:label "E73 Information Object"@en .


###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#E74_Group
:E74_Group rdf:type owl:Class ;
           rdfs:subClassOf :E39_Actor ;
           rdfs:label "E74 Group"@en .


###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#E7_Activity
:E7_Activity rdf:type owl:Class ;
             rdfs:subClassOf :E4_Period ;
             rdfs:label "E7 Activity"@en .


###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#E89_Propositional_Object
:E89_Propositional_Object rdf:type owl:Class ;
                          rdfs:subClassOf :E71_Human-Made_Thing ;
                          rdfs:label "E89 Propositional Object"@en .


###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#E90_Symbolic_Object
:E90_Symbolic_Object rdf:type owl:Class ;
                     rdfs:subClassOf :E89_Propositional_Object ;
                     rdfs:label "E90 Symbolic Object"@en .


###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#E94_Space_Primitive
:E94_Space_Primitive rdf:type owl:Class ;
                     rdfs:subClassOf :E1_CRM_Entity ;
                     rdfs:label "E94 Space Primitive"@en .


###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#EarlyNeolithic
:EarlyNeolithic rdf:type owl:Class ;
                rdfs:subClassOf :Neolithic ;
                rdfs:comment "The earliest phase of the Neolithic, characterised by the initial adoption of agriculture, domestication of plants and animals, and the use of polished stone tools." ;
                rdfs:label "Early Neolithic"@en .


###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Engravings
:Engravings rdf:type owl:Class ;
            rdfs:subClassOf :E90_Symbolic_Object ;
            rdfs:comment "Carved marks or decorations on menhirs." ;
            rdfs:label "Engravings"@en .


###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Excavation
:Excavation rdf:type owl:Class ;
            rdfs:subClassOf :E7_Activity ;
            rdfs:comment "Technical examination of an archaeological site which involves the digging and removal of layers of earth and their associated artefacts." ;
            rdfs:label "Excavation"@en .


###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Fissure
:Fissure rdf:type owl:Class ;
         rdfs:subClassOf :NaturalHeritageSite ;
         rdfs:comment "A narrow opening or crack typically resulting from geological processes." ;
         rdfs:label "Fissure"@en .


###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#FoodVessel
:FoodVessel rdf:type owl:Class ;
            rdfs:subClassOf :Beaker ;
            rdfs:comment "A subtype of Beaker, typically larger and used in funerary contexts." ;
            rdfs:label "Food Vessel"@en .


###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Formation
:Formation rdf:type owl:Class ;
           rdfs:subClassOf :E7_Activity ;
           rdfs:comment "The geological or natural formation of the site or landscape." ;
           rdfs:label "Formation"@en .


###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#GroovedWare
:GroovedWare rdf:type owl:Class ;
             rdfs:subClassOf :ArchaeologicalArtefact ;
             rdfs:comment "Neolithic ceramic tradition characterized by incised decoration" ;
             rdfs:label "Grooved Ware"@en .


###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Hill
:Hill rdf:type owl:Class ;
      rdfs:subClassOf :NaturalHeritageSite ;
      rdfs:comment "A naturally raised area of land, smaller than a mountain." ;
      rdfs:label "Hill"@en .


###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Identification
:Identification rdf:type owl:Class ;
                rdfs:subClassOf :E7_Activity ;
                rdfs:comment "The identification of the archaeological site." ;
                rdfs:label "Identification"@en .


###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Idol
:Idol rdf:type owl:Class ;
      rdfs:subClassOf :ArchaeologicalArtefact ;
      rdfs:comment "Object made with the purpose of fulfilling a religious / ritualistic / symbolic goal." ;
      rdfs:label "Idol"@en .


###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Image
:Image rdf:type owl:Class ;
       rdfs:subClassOf :E31_Document ;
       rdfs:comment "Image FIles" ;
       rdfs:label "Image"@en .


###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Institution
:Institution rdf:type owl:Class ;
             rdfs:subClassOf :E74_Group ;
             rdfs:comment "An organised body responsible for research, preservation, or management of cultural/natural heritage." ;
             rdfs:label "Institution"@en .


###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#IntangibleFeatureGeneral
:IntangibleFeatureGeneral rdf:type owl:Class ;
                          rdfs:subClassOf :E55_Type ;
                          rdfs:comment "General intagible features" ;
                          rdfs:label "Intangible Feature General"@en .


###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#IntangibleFeatureMegalithism
:IntangibleFeatureMegalithism rdf:type owl:Class ;
                              rdfs:subClassOf :E55_Type ;
                              rdfs:comment "Specified to megalithism" ;
                              rdfs:label "Intangible Feature Megalithism"@en .


###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Interview
:Interview rdf:type owl:Class ;
           rdfs:subClassOf :E33_Linguistic_Object ;
           rdfs:comment "Conversations capturing personal or collective testimonies." ;
           rdfs:label "Interview"@en .


###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Lake
:Lake rdf:type owl:Class ;
      rdfs:subClassOf :NaturalHeritageSite ;
      rdfs:comment "A large body of water surrounded by land." ;
      rdfs:label "Lake"@en .


###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Landscape
:Landscape rdf:type owl:Class ;
           rdfs:subClassOf :E26_Physical_Feature ;
           rdfs:comment "Landscape includes physical and natural elements of an environment, as well as human elements such as built structures." ;
           rdfs:label "Landscape"@en .


###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#LateNeolithic
:LateNeolithic rdf:type owl:Class ;
               rdfs:subClassOf :Neolithic ;
               rdfs:comment "The later phase of the Neolithic period, associated with complex societies and megalithic monuments." ;
               rdfs:label "Late Neolithic"@en .


###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#LithicTool
:LithicTool rdf:type owl:Class ;
            rdfs:subClassOf :StoneTool ;
            rdfs:comment "Tool made by knapping stone such as flint, quartz or mylonite" ;
            rdfs:label "Lithic Tool"@en .


###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#LoomWeight
:LoomWeight rdf:type owl:Class ;
            rdfs:subClassOf :ArchaeologicalArtefact ;
            rdfs:comment "Object used in textile production." ;
            rdfs:label "Loom Weight"@en .


###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#MegalithicMonument
:MegalithicMonument rdf:type owl:Class ;
                    rdfs:subClassOf :ArchaeologicalMonument ;
                    rdfs:comment "An archaeological monument built with standing megalithic stones" ;
                    rdfs:label "Megalithic Monument"@en .


###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#MegalithicSite
:MegalithicSite rdf:type owl:Class ;
                rdfs:subClassOf :ArchaeologicalSite ;
                rdfs:comment "A specific geographical area where large stone monuments or constructions, like stones circles or standing stones, are located." ;
                rdfs:label "Megalithic Site"@en .


###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Menhir
:Menhir rdf:type owl:Class ;
        rdfs:subClassOf :MegalithicMonument ;
        rdfs:comment "A standing stone placed in the ground by humans." ;
        rdfs:label "Menhir"@en .


###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#MiddleBronzeAge
:MiddleBronzeAge rdf:type owl:Class ;
                 rdfs:subClassOf :BronzeAge ;
                 rdfs:comment "The middle phase of the Bronze Age" ;
                 rdfs:label "Middle Bronze Age"@en .


###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Municipality
:Municipality rdf:type owl:Class ;
              rdfs:subClassOf :E53_Place ;
              rdfs:comment "Second-level administrative division after district,with its own jurisdiction and local government" ;
              rdfs:label "Municipality"@en .


###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Museum
:Museum rdf:type owl:Class ;
        rdfs:subClassOf :E74_Group ;
        rdfs:comment "A public entity whose efforts involve the acquisition, preservation, research and exhibition of objects with different types of values." ;
        rdfs:label "Museum"@en .


###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Narrative
:Narrative rdf:type owl:Class ;
           rdfs:subClassOf :E33_Linguistic_Object ;
           rdfs:comment "A story/saying that transmits meaning, sentiments and significant memories of a specific place" ;
           rdfs:label "Narrative"@en .


###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#NaturalHeritageSite
:NaturalHeritageSite rdf:type owl:Class ;
                     rdfs:subClassOf :E27_Site ;
                     rdfs:comment "A location of outstanding geological, ecological, or scenic value, often protected for its environmental significance." ;
                     rdfs:label "Natural Heritage Site"@en .


###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#NaturalLandscape
:NaturalLandscape rdf:type owl:Class ;
                  rdfs:subClassOf :Landscape ;
                  rdfs:comment "A landscape predominantly shaped by natural processes, characterised by the absence of significant human intervention or built structures." ;
                  rdfs:label "Natural Landscape"@en .


###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#NaturalSoundscape
:NaturalSoundscape rdf:type owl:Class ;
                   rdfs:subClassOf :Soundscape ;
                   rdfs:comment "Sounds of nature in its characteristic environment." ;
                   rdfs:label "Natural Soundscape"@en .


###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Neolithic
:Neolithic rdf:type owl:Class ;
           rdfs:subClassOf :E4_Period ;
           rdfs:comment "A specific period from pre-history marked by early farming and stone tools." ;
           rdfs:label "Neolithic"@en .


###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#OcupationOrUsage
:OcupationOrUsage rdf:type owl:Class ;
                  rdfs:subClassOf :E7_Activity ;
                  rdfs:comment "The human usage or inhabitation of a site over a period of time." ;
                  rdfs:label "Ocupation Or Usage"@en .


###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#OtherSounds
:OtherSounds rdf:type owl:Class ;
             rdfs:subClassOf :NaturalSoundscape ;
             rdfs:comment "Other sounds." ;
             rdfs:label "Other Sounds"@en .


###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Paleoproterozoic
:Paleoproterozoic rdf:type owl:Class ;
                  rdfs:subClassOf :E4_Period ;
                  rdfs:comment "A geological period dating from approximately 2.5 to 1.6 billion years ago." ;
                  rdfs:label "Paleoproterozoic"@en .


###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Parish
:Parish rdf:type owl:Class ;
        rdfs:subClassOf :E53_Place ;
        rdfs:comment "A minor administrative division, sub part of Municipalities" ;
        rdfs:label "Parish"@en .


###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Park
:Park rdf:type owl:Class ;
      rdfs:subClassOf :NaturalHeritageSite ;
      rdfs:comment "A designated area preserved for its natural environment and public enjoyment." ;
      rdfs:label "Park"@en .


###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#PlaqueIdol
:PlaqueIdol rdf:type owl:Class ;
            rdfs:subClassOf :Idol ;
            rdfs:comment """An idol in the shape of a plaque (engraved stone
plaques)""" ;
            rdfs:label "Plaque Idol"@en .


###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Region
:Region rdf:type owl:Class ;
        rdfs:subClassOf :E53_Place ;
        rdfs:comment "A geographical unit that can aggregate multiple districts" ;
        rdfs:label "Region"@en .


###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Restoration
:Restoration rdf:type owl:Class ;
             rdfs:subClassOf :E7_Activity ;
             rdfs:comment "The restoration of components of the archaeological site." ;
             rdfs:label "Restoration"@en .


###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Roll_up
:Roll_up rdf:type owl:Class ;
         rdfs:subClassOf :E31_Document ;
         rdfs:comment "Roll ups of the exhibition" ;
         rdfs:label "Roll up"@en .


###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Romanticism
:Romanticism rdf:type owl:Class ;
             rdfs:subClassOf :E7_Activity ;
             rdfs:comment "An artistic and intellectual movement emphasizing nature, emotion, and individualism, often associated with the 19th century." ;
             rdfs:label "Romanticism"@en .


###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#RuralLandscape
:RuralLandscape rdf:type owl:Class ;
                rdfs:subClassOf :CulturalLandscape ;
                rdfs:comment "Landscape characterised by open fields, low population and green areas with diverse vegetation." ;
                rdfs:label "Rural Landscape"@en .


###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#SoundsOfTheTreeBranches
:SoundsOfTheTreeBranches rdf:type owl:Class ;
                         rdfs:subClassOf :NaturalSoundscape ;
                         rdfs:comment "Sounds of tree branches moving." ;
                         rdfs:label "Sounds Of The Tree Branches"@en .


###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#SoundsOfTheWindBlowing
:SoundsOfTheWindBlowing rdf:type owl:Class ;
                        rdfs:subClassOf :NaturalSoundscape ;
                        rdfs:comment "Sounds of blowing wind" ;
                        rdfs:label "Sounds Of The Wind Blowing"@en .


###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Soundscape
:Soundscape rdf:type owl:Class ;
            rdfs:subClassOf :E26_Physical_Feature ;
            rdfs:comment "Set of sounds typical from an environment." ;
            rdfs:label "Soundscape"@en .


###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#SpiritualOrRitualSite
:SpiritualOrRitualSite rdf:type owl:Class ;
                       rdfs:subClassOf :E27_Site ;
                       rdfs:comment "A location where ancient religious or ceremonial/ritualistic practices were/are conducted." ;
                       rdfs:label "Spiritual Or Ritual Site"@en .


###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#StoneCircleOrCromlech
:StoneCircleOrCromlech rdf:type owl:Class ;
                       rdfs:subClassOf :MegalithicMonument ;
                       rdfs:comment "An arrangement of standing stones (menhirs) placed by humans." ;
                       rdfs:label "Stone Circle Or Cromlech"@en .


###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#StoneTool
:StoneTool rdf:type owl:Class ;
           rdfs:subClassOf :ArchaeologicalArtefact ;
           rdfs:comment "A general-purpose manually shaped stone implement" ;
           rdfs:label "Stone Tool"@en .


###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Text
:Text rdf:type owl:Class ;
      rdfs:subClassOf :E31_Document ;
      rdfs:comment "The written files of the interviews" ;
      rdfs:label "Text"@en .


###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#TouristicSite
:TouristicSite rdf:type owl:Class ;
               rdfs:subClassOf :E27_Site ;
               rdfs:comment "A space open to visitors." ;
               rdfs:label "Touristic Site"@en .


###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Trigger
:Trigger rdf:type owl:Class ;
         rdfs:subClassOf :E73_Information_Object ;
         rdfs:comment "A element that evokes a intangible heritage experience" ;
         rdfs:label "Trigger"@en .


###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#UrbanLandscape
:UrbanLandscape rdf:type owl:Class ;
                rdfs:subClassOf :CulturalLandscape ;
                rdfs:comment "A space, like a city, that contains physical and visual elements built by humans." ;
                rdfs:label "Urban Landscape"@en .


###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Video
:Video rdf:type owl:Class ;
       rdfs:subClassOf :E31_Document ;
       rdfs:comment "Video files" ;
       rdfs:label "Video"@en .


###  http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Volunteer
:Volunteer rdf:type owl:Class ;
           rdfs:subClassOf :E21_Person ;
           rdfs:comment "Committed participant without a professional background, actively involved in fieldwork" ;
           rdfs:label "Volunteer"@en .


