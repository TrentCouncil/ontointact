        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#E71_Human-Made_Thing"/>
        <rdfs:label xml:lang="en">E24 Physical Human Made Thing</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#E26_Physical_Feature -->


    <owl:Class rdf:about="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#E26_Physical_Feature">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#E18_Physical_Thing"/>
        <rdfs:label xml:lang="en">E26 Physical Feature</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#E27_Site -->


    <owl:Class rdf:about="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#E27_Site">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#E26_Physical_Feature"/>
        <rdfs:comment>This class comprises pieces of land or sea floor. In contrast to the purely geometric notion of E53 Place, this class describes constellations of matter on the surface of the Earth or other celestial body, which can be represented by photographs, paintings and maps. Instances of E27 Site are composed of relatively immobile material items and features in a particular configuration at a particular location.</rdfs:comment>
        <rdfs:label xml:lang="en">Site</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#E2_Temporal_Entity -->


