        <rdfs:comment>Image FIles</rdfs:comment>
        <rdfs:label xml:lang="en">Image</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Institution -->


    <owl:Class rdf:about="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Institution">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#E74_Group"/>
        <rdfs:comment>An organised body responsible for research, preservation, or management of cultural/natural heritage.</rdfs:comment>
        <rdfs:label xml:lang="en">Institution</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Intangible_Feature -->


    <owl:Class rdf:about="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Intangible_Feature">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#E55_Type"/>
        <rdfs:label>Intangible Feature</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Interview -->


    <owl:Class rdf:about="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Interview">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#E33_Linguistic_Object"/>
        <rdfs:comment>Conversations capturing personal or collective testimonies.</rdfs:comment>
        <rdfs:label xml:lang="en">Interview</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Lake -->


    <owl:Class rdf:about="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Lake">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#NaturalHeritageSite"/>
        <rdfs:comment>A large body of water surrounded by land.</rdfs:comment>
        <rdfs:label xml:lang="en">Lake</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Landscape -->


    <owl:Class rdf:about="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Landscape">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#E26_Physical_Feature"/>
        <rdfs:comment>Landscape includes physical and natural elements of an environment, as well as human elements such as built structures.</rdfs:comment>
        <rdfs:label xml:lang="en">Landscape</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#LateNeolithic -->


    <owl:Class rdf:about="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#LateNeolithic">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Neolithic"/>
        <rdfs:comment>The later phase of the Neolithic period, associated with complex societies and megalithic monuments.</rdfs:comment>
        <rdfs:label xml:lang="en">Late Neolithic</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#LithicTool -->


    <owl:Class rdf:about="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#LithicTool">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#StoneTool"/>
        <rdfs:comment>Tool made by knapping stone such as flint, quartz or mylonite</rdfs:comment>
        <rdfs:label xml:lang="en">Lithic Tool</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#LoomWeight -->


    <owl:Class rdf:about="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#LoomWeight">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#ArchaeologicalArtefact"/>
        <rdfs:comment>Object used in textile production.</rdfs:comment>
        <rdfs:label xml:lang="en">Loom Weight</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#MegalithicMonument -->


    <owl:Class rdf:about="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#MegalithicMonument">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#ArchaeologicalMonument"/>
        <rdfs:comment>An archaeological monument built with standing megalithic stones</rdfs:comment>
        <rdfs:label xml:lang="en">Megalithic Monument</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#MegalithicSite -->


    <owl:Class rdf:about="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#MegalithicSite">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#ArchaeologicalSite"/>
        <rdfs:comment>A specific geographical area where large stone monuments or constructions, like stones circles or standing stones, are located.</rdfs:comment>
        <rdfs:label xml:lang="en">Megalithic Site</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Menhir -->


    <owl:Class rdf:about="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Menhir">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#MegalithicMonument"/>
        <rdfs:comment>A standing stone placed in the ground by humans.</rdfs:comment>
        <rdfs:label xml:lang="en">Menhir</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#MiddleBronzeAge -->


    <owl:Class rdf:about="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#MiddleBronzeAge">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#BronzeAge"/>
        <rdfs:comment>The middle phase of the Bronze Age</rdfs:comment>
        <rdfs:label xml:lang="en">Middle Bronze Age</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Municipality -->


    <owl:Class rdf:about="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Municipality">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#E53_Place"/>
        <rdfs:comment>Second-level administrative division after district,with its own jurisdiction and local government</rdfs:comment>
        <rdfs:label xml:lang="en">Municipality</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Museum -->


    <owl:Class rdf:about="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Museum">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#E74_Group"/>
        <rdfs:comment>A public entity whose efforts involve the acquisition, preservation, research and exhibition of objects with different types of values.</rdfs:comment>
        <rdfs:label xml:lang="en">Museum</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Narrative -->


    <owl:Class rdf:about="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Narrative">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#E33_Linguistic_Object"/>
        <rdfs:comment>A story/saying that transmits meaning, sentiments and significant memories of a specific place</rdfs:comment>
        <rdfs:label xml:lang="en">Narrative</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#NaturalHeritageSite -->


    <owl:Class rdf:about="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#NaturalHeritageSite">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#E27_Site"/>
        <rdfs:comment>A location of outstanding geological, ecological, or scenic value, often protected for its environmental significance.</rdfs:comment>
        <rdfs:label xml:lang="en">Natural Heritage Site</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#NaturalLandscape -->


    <owl:Class rdf:about="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#NaturalLandscape">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Landscape"/>
        <rdfs:comment>A landscape predominantly shaped by natural processes, characterised by the absence of significant human intervention or built structures.</rdfs:comment>
        <rdfs:label xml:lang="en">Natural Landscape</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#NaturalSoundscape -->


    <owl:Class rdf:about="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#NaturalSoundscape">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Soundscape"/>
        <rdfs:comment>Sounds of nature in its characteristic environment.</rdfs:comment>
        <rdfs:label xml:lang="en">Natural Soundscape</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Neolithic -->


    <owl:Class rdf:about="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Neolithic">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#E4_Period"/>
        <rdfs:comment>A specific period from pre-history marked by early farming and stone tools.</rdfs:comment>
        <rdfs:label xml:lang="en">Neolithic</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#OcupationOrUsage -->


    <owl:Class rdf:about="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#OcupationOrUsage">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#E7_Activity"/>
        <rdfs:comment>The human usage or inhabitation of a site over a period of time.</rdfs:comment>
        <rdfs:label xml:lang="en">Ocupation Or Usage</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#OtherSounds -->


    <owl:Class rdf:about="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#OtherSounds">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#NaturalSoundscape"/>
        <rdfs:comment>Other sounds.</rdfs:comment>
        <rdfs:label xml:lang="en">Other Sounds</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Paleoproterozoic -->


    <owl:Class rdf:about="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Paleoproterozoic">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#E4_Period"/>
        <rdfs:comment>A geological period dating from approximately 2.5 to 1.6 billion years ago.</rdfs:comment>
        <rdfs:label xml:lang="en">Paleoproterozoic</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Parish -->


    <owl:Class rdf:about="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Parish">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#E53_Place"/>
        <rdfs:comment>A minor administrative division, sub part of Municipalities</rdfs:comment>
        <rdfs:label xml:lang="en">Parish</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Park -->


    <owl:Class rdf:about="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Park">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#NaturalHeritageSite"/>
        <rdfs:comment>A designated area preserved for its natural environment and public enjoyment.</rdfs:comment>
        <rdfs:label xml:lang="en">Park</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#PlaqueIdol -->


    <owl:Class rdf:about="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#PlaqueIdol">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Idol"/>
        <rdfs:comment>An idol in the shape of a plaque (engraved stone
plaques)</rdfs:comment>
        <rdfs:label xml:lang="en">Plaque Idol</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Region -->


    <owl:Class rdf:about="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Region">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#E53_Place"/>
        <rdfs:comment>A geographical unit that can aggregate multiple districts</rdfs:comment>
        <rdfs:label xml:lang="en">Region</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Restoration -->


    <owl:Class rdf:about="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Restoration">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#E7_Activity"/>
        <rdfs:comment>The restoration of components of the archaeological site.</rdfs:comment>
        <rdfs:label xml:lang="en">Restoration</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Roll_up -->


    <owl:Class rdf:about="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Roll_up">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#E31_Document"/>
        <rdfs:comment>Roll ups of the exhibition</rdfs:comment>
        <rdfs:label xml:lang="en">Roll up</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Romanticism -->


    <owl:Class rdf:about="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Romanticism">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#E7_Activity"/>
        <rdfs:comment>An artistic and intellectual movement emphasizing nature, emotion, and individualism, often associated with the 19th century.</rdfs:comment>
        <rdfs:label xml:lang="en">Romanticism</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#RuralLandscape -->


    <owl:Class rdf:about="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#RuralLandscape">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#CulturalLandscape"/>
        <rdfs:comment>Landscape characterised by open fields, low population and green areas with diverse vegetation.</rdfs:comment>
        <rdfs:label xml:lang="en">Rural Landscape</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#SoundsOfTheTreeBranches -->


    <owl:Class rdf:about="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#SoundsOfTheTreeBranches">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#NaturalSoundscape"/>
        <rdfs:comment>Sounds of tree branches moving.</rdfs:comment>
        <rdfs:label xml:lang="en">Sounds Of The Tree Branches</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#SoundsOfTheWindBlowing -->


    <owl:Class rdf:about="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#SoundsOfTheWindBlowing">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#NaturalSoundscape"/>
        <rdfs:comment>Sounds of blowing wind</rdfs:comment>
        <rdfs:label xml:lang="en">Sounds Of The Wind Blowing</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Soundscape -->


    <owl:Class rdf:about="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Soundscape">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#E26_Physical_Feature"/>
        <rdfs:comment>Set of sounds typical from an environment.</rdfs:comment>
        <rdfs:label xml:lang="en">Soundscape</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#SpiritualOrRitualSite -->


    <owl:Class rdf:about="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#SpiritualOrRitualSite">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#E27_Site"/>
        <rdfs:comment>A location where ancient religious or ceremonial/ritualistic practices were/are conducted.</rdfs:comment>
        <rdfs:label xml:lang="en">Spiritual Or Ritual Site</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#StoneCircleOrCromlech -->


    <owl:Class rdf:about="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#StoneCircleOrCromlech">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#MegalithicMonument"/>
        <rdfs:comment>An arrangement of standing stones (menhirs) placed by humans.</rdfs:comment>
        <rdfs:label xml:lang="en">Stone Circle Or Cromlech</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#StoneTool -->


    <owl:Class rdf:about="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#StoneTool">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#ArchaeologicalArtefact"/>
        <rdfs:comment>A general-purpose manually shaped stone implement</rdfs:comment>
        <rdfs:label xml:lang="en">Stone Tool</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Text -->


    <owl:Class rdf:about="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Text">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#E31_Document"/>
        <rdfs:comment>The written files of the interviews</rdfs:comment>
        <rdfs:label xml:lang="en">Text</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#TouristicSite -->


    <owl:Class rdf:about="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#TouristicSite">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#E27_Site"/>
        <rdfs:comment>A space open to visitors.</rdfs:comment>
        <rdfs:label xml:lang="en">Touristic Site</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#UrbanLandscape -->


    <owl:Class rdf:about="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#UrbanLandscape">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#CulturalLandscape"/>
        <rdfs:comment>A space, like a city, that contains physical and visual elements built by humans.</rdfs:comment>
        <rdfs:label xml:lang="en">Urban Landscape</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Video -->


    <owl:Class rdf:about="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Video">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#E31_Document"/>
        <rdfs:comment>Video files</rdfs:comment>
        <rdfs:label xml:lang="en">Video</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Volunteer -->


    <owl:Class rdf:about="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Volunteer">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#E21_Person"/>
        <rdfs:comment>Committed participant without a professional background, actively involved in fieldwork</rdfs:comment>
        <rdfs:label xml:lang="en">Volunteer</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#3DModel -->


    <owl:Class rdf:about="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#3DModel">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#E31_Document"/>
        <rdfs:comment>3D model files</rdfs:comment>
        <rdfs:label xml:lang="en">3D Model</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Patron/Promoter -->


    <owl:Class rdf:about="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Patron/Promoter">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#E39_Actor"/>
