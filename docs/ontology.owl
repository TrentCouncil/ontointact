        <rdfs:label xml:lang="en">Cultural Heritage Monument</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#CulturalHeritageSite -->


    <owl:Class rdf:about="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#CulturalHeritageSite">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#E27_Site"/>
        <rdfs:comment>A place of importance recognised for its historical and cultural value</rdfs:comment>
        <rdfs:label xml:lang="en">Cultural Heritage Site</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#CulturalLandscape -->


    <owl:Class rdf:about="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#CulturalLandscape">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Landscape"/>
        <rdfs:comment>A landscape containing features made by humans. It can be protected as a cultural heritage site.</rdfs:comment>
        <rdfs:label xml:lang="en">Cultural Landscape</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#CulturalLandscapeSite -->


    <owl:Class rdf:about="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#CulturalLandscapeSite">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#E27_Site"/>
        <rdfs:comment>A landscape that has been shaped or symbolically interpreted through cultural practices, beliefs, or artistic representation.</rdfs:comment>
        <rdfs:label xml:lang="en">Cultural Landscape Site</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Demonstrator -->


    <owl:Class rdf:about="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Demonstrator">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#E71_Human-Made_Thing"/>
        <rdfs:comment>A prototype or tool created to showcase a concept or functionality</rdfs:comment>
        <rdfs:label xml:lang="en">Demonstrator</rdfs:label>
    </owl:Class>
    


