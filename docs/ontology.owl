        <rdfs:label xml:lang="en">E94 Space Primitive</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#EarlyNeolithic -->


    <owl:Class rdf:about="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#EarlyNeolithic">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Neolithic"/>
        <rdfs:comment>The earliest phase of the Neolithic, characterised by the initial adoption of agriculture, domestication of plants and animals, and the use of polished stone tools.</rdfs:comment>
        <rdfs:label xml:lang="en">Early Neolithic</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Engravings -->


    <owl:Class rdf:about="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Engravings">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#E90_Symbolic_Object"/>
        <rdfs:comment>Carved marks or decorations on menhirs.</rdfs:comment>
        <rdfs:label xml:lang="en">Engravings</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Excavation -->


    <owl:Class rdf:about="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Excavation">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#E7_Activity"/>
        <rdfs:comment>Technical examination of an archaeological site which involves the digging and removal of layers of earth and their associated artefacts.</rdfs:comment>
        <rdfs:label xml:lang="en">Excavation</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Fissure -->


    <owl:Class rdf:about="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Fissure">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#NaturalHeritageSite"/>
        <rdfs:comment>A narrow opening or crack typically resulting from geological processes.</rdfs:comment>
        <rdfs:label xml:lang="en">Fissure</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#FoodVessel -->


    <owl:Class rdf:about="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#FoodVessel">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Beaker"/>
        <rdfs:comment>A subtype of Beaker, typically larger and used in funerary contexts.</rdfs:comment>
        <rdfs:label xml:lang="en">Food Vessel</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Formation -->


    <owl:Class rdf:about="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Formation">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#E7_Activity"/>
        <rdfs:comment>The geological or natural formation of the site or landscape.</rdfs:comment>
        <rdfs:label xml:lang="en">Formation</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#GroovedWare -->


    <owl:Class rdf:about="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#GroovedWare">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#ArchaeologicalArtefact"/>
        <rdfs:comment>Neolithic ceramic tradition characterized by incised decoration</rdfs:comment>
        <rdfs:label xml:lang="en">Grooved Ware</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Hill -->


    <owl:Class rdf:about="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Hill">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#NaturalHeritageSite"/>
        <rdfs:comment>A naturally raised area of land, smaller than a mountain.</rdfs:comment>
        <rdfs:label xml:lang="en">Hill</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Identification -->


    <owl:Class rdf:about="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Identification">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#E7_Activity"/>
        <rdfs:comment>The identification of the archaeological site.</rdfs:comment>
        <rdfs:label xml:lang="en">Identification</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Idol -->


    <owl:Class rdf:about="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Idol">
