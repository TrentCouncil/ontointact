<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#"
     xml:base="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:skos="http://www.w3.org/2004/02/skos/core#"
     xmlns:terms="http://purl.org/dc/terms/"
     xmlns:untitled-ontology-30="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#">
    <owl:Ontology rdf:about="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30">
        <owl:versionIRI rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30/1.0.0"/>
        <terms:creator>INT-ACT UÉvora Team</terms:creator>
        <terms:license rdf:resource="https://creativecommons.org/licenses/by/4.0/"/>
        <terms:title>INT-ACT Ontology</terms:title>
        <rdfs:comment>This ontology reuses and integrates the SKOS (Simple Knowledge Organization System) vocabulary for the organisation of domain-specific concepts, and builds upon the CIDOC Conceptual Reference Model (CRM) for the representation of cultural heritage entities and events.</rdfs:comment>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://purl.org/dc/terms/contributor -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/contributor"/>
    


    <!-- http://purl.org/dc/terms/creator -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/creator"/>
    


    <!-- http://purl.org/dc/terms/description -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/description"/>
    


    <!-- http://purl.org/dc/terms/license -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/license"/>
    


    <!-- http://purl.org/dc/terms/title -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/title"/>
    


    <!-- http://www.w3.org/2004/02/skos/core#altLabel -->


    <owl:AnnotationProperty rdf:about="http://www.w3.org/2004/02/skos/core#altLabel">
        <rdfs:comment xml:lang="en">The range of skos:altLabel is the class of RDF plain literals.</rdfs:comment>
        <rdfs:comment xml:lang="en">skos:prefLabel, skos:altLabel and skos:hiddenLabel are pairwise disjoint properties.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://www.w3.org/2004/02/skos/core"/>
        <skos:definition xml:lang="en">An alternative lexical label for a resource.</skos:definition>
        <skos:example xml:lang="en">Acronyms, abbreviations, spelling variants, and irregular plural/singular forms may be included among the alternative labels for a concept. Mis-spelled terms are normally included as hidden labels (see skos:hiddenLabel).</skos:example>
    </owl:AnnotationProperty>
    


    <!-- http://www.w3.org/2004/02/skos/core#changeNote -->


    <owl:AnnotationProperty rdf:about="http://www.w3.org/2004/02/skos/core#changeNote">
        <rdfs:isDefinedBy rdf:resource="http://www.w3.org/2004/02/skos/core"/>
        <skos:definition xml:lang="en">A note about a modification to a concept.</skos:definition>
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2004/02/skos/core#note"/>
    </owl:AnnotationProperty>
    


    <!-- http://www.w3.org/2004/02/skos/core#definition -->


    <owl:AnnotationProperty rdf:about="http://www.w3.org/2004/02/skos/core#definition">
        <rdfs:isDefinedBy rdf:resource="http://www.w3.org/2004/02/skos/core"/>
        <skos:definition xml:lang="en">A statement or formal explanation of the meaning of a concept.</skos:definition>
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2004/02/skos/core#note"/>
    </owl:AnnotationProperty>
    


    <!-- http://www.w3.org/2004/02/skos/core#editorialNote -->


    <owl:AnnotationProperty rdf:about="http://www.w3.org/2004/02/skos/core#editorialNote">
        <rdfs:isDefinedBy rdf:resource="http://www.w3.org/2004/02/skos/core"/>
        <skos:definition xml:lang="en">A note for an editor, translator or maintainer of the vocabulary.</skos:definition>
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2004/02/skos/core#note"/>
    </owl:AnnotationProperty>
    


    <!-- http://www.w3.org/2004/02/skos/core#example -->


    <owl:AnnotationProperty rdf:about="http://www.w3.org/2004/02/skos/core#example">
        <rdfs:isDefinedBy rdf:resource="http://www.w3.org/2004/02/skos/core"/>
        <skos:definition xml:lang="en">An example of the use of a concept.</skos:definition>
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2004/02/skos/core#note"/>
    </owl:AnnotationProperty>
    


    <!-- http://www.w3.org/2004/02/skos/core#hiddenLabel -->


    <owl:AnnotationProperty rdf:about="http://www.w3.org/2004/02/skos/core#hiddenLabel">
        <rdfs:comment xml:lang="en">The range of skos:hiddenLabel is the class of RDF plain literals.</rdfs:comment>
        <rdfs:comment xml:lang="en">skos:prefLabel, skos:altLabel and skos:hiddenLabel are pairwise disjoint properties.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://www.w3.org/2004/02/skos/core"/>
        <skos:definition xml:lang="en">A lexical label for a resource that should be hidden when generating visual displays of the resource, but should still be accessible to free text search operations.</skos:definition>
    </owl:AnnotationProperty>
    


    <!-- http://www.w3.org/2004/02/skos/core#historyNote -->


    <owl:AnnotationProperty rdf:about="http://www.w3.org/2004/02/skos/core#historyNote">
        <rdfs:isDefinedBy rdf:resource="http://www.w3.org/2004/02/skos/core"/>
        <skos:definition xml:lang="en">A note about the past state/use/meaning of a concept.</skos:definition>
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2004/02/skos/core#note"/>
    </owl:AnnotationProperty>
    


    <!-- http://www.w3.org/2004/02/skos/core#note -->


    <owl:AnnotationProperty rdf:about="http://www.w3.org/2004/02/skos/core#note">
        <rdfs:isDefinedBy rdf:resource="http://www.w3.org/2004/02/skos/core"/>
        <skos:definition xml:lang="en">A general note, for any purpose.</skos:definition>
        <skos:scopeNote xml:lang="en">This property may be used directly, or as a super-property for more specific note types.</skos:scopeNote>
    </owl:AnnotationProperty>
    


    <!-- http://www.w3.org/2004/02/skos/core#prefLabel -->


    <owl:AnnotationProperty rdf:about="http://www.w3.org/2004/02/skos/core#prefLabel">
        <rdfs:comment xml:lang="en">A resource has no more than one value of skos:prefLabel per language tag, and no more than one value of skos:prefLabel without language tag.</rdfs:comment>
        <rdfs:comment xml:lang="en">The range of skos:prefLabel is the class of RDF plain literals.</rdfs:comment>
        <rdfs:comment xml:lang="en">skos:prefLabel, skos:altLabel and skos:hiddenLabel are pairwise
      disjoint properties.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://www.w3.org/2004/02/skos/core"/>
        <skos:definition xml:lang="en">The preferred lexical label for a resource, in a given language.</skos:definition>
    </owl:AnnotationProperty>
    


    <!-- http://www.w3.org/2004/02/skos/core#scopeNote -->


    <owl:AnnotationProperty rdf:about="http://www.w3.org/2004/02/skos/core#scopeNote">
        <rdfs:isDefinedBy rdf:resource="http://www.w3.org/2004/02/skos/core"/>
        <skos:definition xml:lang="en">A note that helps to clarify the meaning and/or the use of a concept.</skos:definition>
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2004/02/skos/core#note"/>
    </owl:AnnotationProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#P129_isAbout -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#P129_isAbout">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#E89_Propositional_Object"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#E1_CRM_Entity"/>
        <rdfs:label xml:lang="en">is About</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#P130_shows_features_of -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#P130_shows_features_of">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#E70_Thing"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#E70_Thing"/>
        <rdfs:label xml:lang="en">shows features of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#P14_carriedOutBy -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#P14_carriedOutBy">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#E7_Activity"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#E39_Actor"/>
        <rdfs:label xml:lang="en">carried Out By</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#P165_incorporates -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#P165_incorporates">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#E89_Propositional_Object"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#E90_Symbolic_Object"/>
        <rdfs:label xml:lang="en">incorporates</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#P198_holds_or_supports -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#P198_holds_or_supports">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#E18_Physical_Thing"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#E18_Physical_Thing"/>
        <rdfs:label xml:lang="en">holds or supports</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#P46_IsComposedOf -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#P46_IsComposedOf">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#E18_Physical_Thing"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#E18_Physical_Thing"/>
        <rdfs:label xml:lang="en">Is Composed Of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#P4_hasTimeSpan -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#P4_hasTimeSpan">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#E2_Temporal_Entity"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#E52_TimeSpan"/>
        <rdfs:label xml:lang="en">has Time Span</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#P53_has_former_or_current_location -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#P53_has_former_or_current_location">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#E18_Physical_Thing"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#E53_Place"/>
        <rdfs:label xml:lang="en">has former or current location</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#P89_falls_within -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#P89_falls_within">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#E53_Place"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#E53_Place"/>
        <rdfs:label xml:lang="en">falls within</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#P8_took_place_on_or_within -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#P8_took_place_on_or_within">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#E4_Period"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#E18_Physical_Thing"/>
        <rdfs:label xml:lang="en">took place on or within</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#hasArtisticTimeSpan -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#hasArtisticTimeSpan">
        <rdfs:subPropertyOf rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#P4_hasTimeSpan"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Romanticism"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#E52_TimeSpan"/>
        <rdfs:label xml:lang="en">has Artistic Time Span</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#hasClimate -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#hasClimate">
        <rdfs:subPropertyOf rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#P130_shows_features_of"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#E53_Place"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Climate"/>
        <rdfs:label xml:lang="en">has Climate</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#hasConstructionTimeSpan -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#hasConstructionTimeSpan">
        <rdfs:subPropertyOf rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#P4_hasTimeSpan"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Construction"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#E52_TimeSpan"/>
        <rdfs:label xml:lang="en">has Construction Time Span</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#hasEngravings -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#hasEngravings">
        <rdfs:subPropertyOf rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#P130_shows_features_of"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Menhir"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Engravings"/>
        <rdfs:label xml:lang="en">has Engravings</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#hasExcavationTimeSpan -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#hasExcavationTimeSpan">
        <rdfs:subPropertyOf rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#P4_hasTimeSpan"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Excavation"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#E52_TimeSpan"/>
        <rdfs:label xml:lang="en">has Excavation Time Span</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#hasFormationTimeSpan -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#hasFormationTimeSpan">
        <rdfs:subPropertyOf rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#P4_hasTimeSpan"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Formation"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#E52_TimeSpan"/>
        <rdfs:label xml:lang="en">has Formation Time Span</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#hasIdentificationTimeSpan -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#hasIdentificationTimeSpan">
        <rdfs:subPropertyOf rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#P4_hasTimeSpan"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Identification"/>
        <rdfs:label xml:lang="en">has Identification Time Span</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#hasMegalithicComponents -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#hasMegalithicComponents">
        <rdfs:subPropertyOf rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#P46_IsComposedOf"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#StoneCircleOrCromlech"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Menhir"/>
        <rdfs:label xml:lang="en">has Megalithic Components</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#hasTypicalLandscape -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#hasTypicalLandscape">
        <rdfs:subPropertyOf rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#P130_shows_features_of"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#E53_Place"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Landscape"/>
        <rdfs:label xml:lang="en">has Typical Landscape</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#hasUsageTimeSpan -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#hasUsageTimeSpan">
        <rdfs:subPropertyOf rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#P4_hasTimeSpan"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#OcupationOrUsage"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#E52_TimeSpan"/>
        <rdfs:label xml:lang="en">has Usage Time Span</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/2004/02/skos/core#broadMatch -->


    <owl:ObjectProperty rdf:about="http://www.w3.org/2004/02/skos/core#broadMatch">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2004/02/skos/core#broader"/>
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2004/02/skos/core#mappingRelation"/>
        <owl:inverseOf rdf:resource="http://www.w3.org/2004/02/skos/core#narrowMatch"/>
        <rdfs:isDefinedBy rdf:resource="http://www.w3.org/2004/02/skos/core"/>
        <skos:definition xml:lang="en">skos:broadMatch is used to state a hierarchical mapping link between two conceptual resources in different concept schemes.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/2004/02/skos/core#broader -->


    <owl:ObjectProperty rdf:about="http://www.w3.org/2004/02/skos/core#broader">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2004/02/skos/core#broaderTransitive"/>
        <owl:inverseOf rdf:resource="http://www.w3.org/2004/02/skos/core#narrower"/>
        <rdfs:comment xml:lang="en">Broader concepts are typically rendered as parents in a concept hierarchy (tree).</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://www.w3.org/2004/02/skos/core"/>
        <skos:definition xml:lang="en">Relates a concept to a concept that is more general in meaning.</skos:definition>
        <skos:scopeNote xml:lang="en">By convention, skos:broader is only used to assert an immediate (i.e. direct) hierarchical link between two conceptual resources.</skos:scopeNote>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/2004/02/skos/core#broaderTransitive -->


    <owl:ObjectProperty rdf:about="http://www.w3.org/2004/02/skos/core#broaderTransitive">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2004/02/skos/core#semanticRelation"/>
        <owl:inverseOf rdf:resource="http://www.w3.org/2004/02/skos/core#narrowerTransitive"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <rdfs:isDefinedBy rdf:resource="http://www.w3.org/2004/02/skos/core"/>
        <skos:definition>skos:broaderTransitive is a transitive superproperty of skos:broader.</skos:definition>
        <skos:scopeNote xml:lang="en">By convention, skos:broaderTransitive is not used to make assertions. Rather, the properties can be used to draw inferences about the transitive closure of the hierarchical relation, which is useful e.g. when implementing a simple query expansion algorithm in a search application.</skos:scopeNote>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/2004/02/skos/core#closeMatch -->


    <owl:ObjectProperty rdf:about="http://www.w3.org/2004/02/skos/core#closeMatch">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2004/02/skos/core#mappingRelation"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
        <rdfs:isDefinedBy rdf:resource="http://www.w3.org/2004/02/skos/core"/>
        <skos:definition xml:lang="en">skos:closeMatch is used to link two concepts that are sufficiently similar that they can be used interchangeably in some information retrieval applications. In order to avoid the possibility of &quot;compound errors&quot; when combining mappings across more than two concept schemes, skos:closeMatch is not declared to be a transitive property.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/2004/02/skos/core#exactMatch -->


    <owl:ObjectProperty rdf:about="http://www.w3.org/2004/02/skos/core#exactMatch">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2004/02/skos/core#closeMatch"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <rdfs:comment xml:lang="en">skos:exactMatch is disjoint with each of the properties skos:broadMatch and skos:relatedMatch.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://www.w3.org/2004/02/skos/core"/>
        <skos:definition xml:lang="en">skos:exactMatch is used to link two concepts, indicating a high degree of confidence that the concepts can be used interchangeably across a wide range of information retrieval applications. skos:exactMatch is a transitive property, and is a sub-property of skos:closeMatch.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/2004/02/skos/core#hasTopConcept -->


    <owl:ObjectProperty rdf:about="http://www.w3.org/2004/02/skos/core#hasTopConcept">
        <owl:inverseOf rdf:resource="http://www.w3.org/2004/02/skos/core#topConceptOf"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2004/02/skos/core#ConceptScheme"/>
        <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdfs:isDefinedBy rdf:resource="http://www.w3.org/2004/02/skos/core"/>
        <skos:definition xml:lang="en">Relates, by convention, a concept scheme to a concept which is topmost in the broader/narrower concept hierarchies for that scheme, providing an entry point to these hierarchies.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/2004/02/skos/core#inScheme -->


    <owl:ObjectProperty rdf:about="http://www.w3.org/2004/02/skos/core#inScheme">
        <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#ConceptScheme"/>
        <rdfs:isDefinedBy rdf:resource="http://www.w3.org/2004/02/skos/core"/>
        <skos:definition xml:lang="en">Relates a resource (for example a concept) to a concept scheme in which it is included.</skos:definition>
        <skos:scopeNote xml:lang="en">A concept may be a member of more than one concept scheme.</skos:scopeNote>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/2004/02/skos/core#mappingRelation -->


    <owl:ObjectProperty rdf:about="http://www.w3.org/2004/02/skos/core#mappingRelation">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2004/02/skos/core#semanticRelation"/>
        <rdfs:comment xml:lang="en">These concept mapping relations mirror semantic relations, and the data model defined below is similar (with the exception of skos:exactMatch) to the data model defined for semantic relations. A distinct vocabulary is provided for concept mapping relations, to provide a convenient way to differentiate links within a concept scheme from links between concept schemes. However, this pattern of usage is not a formal requirement of the SKOS data model, and relies on informal definitions of best practice.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://www.w3.org/2004/02/skos/core"/>
        <skos:definition xml:lang="en">Relates two concepts coming, by convention, from different schemes, and that have comparable meanings</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/2004/02/skos/core#member -->


    <owl:ObjectProperty rdf:about="http://www.w3.org/2004/02/skos/core#member">
        <rdfs:domain rdf:resource="http://www.w3.org/2004/02/skos/core#Collection"/>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.w3.org/2004/02/skos/core#Collection"/>
                    <rdf:Description rdf:about="http://www.w3.org/2004/02/skos/core#Concept"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:isDefinedBy rdf:resource="http://www.w3.org/2004/02/skos/core"/>
        <skos:definition xml:lang="en">Relates a collection to one of its members.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/2004/02/skos/core#memberList -->


    <owl:ObjectProperty rdf:about="http://www.w3.org/2004/02/skos/core#memberList">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2004/02/skos/core#OrderedCollection"/>
        <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
        <rdfs:comment xml:lang="en">For any resource, every item in the list given as the value of the
      skos:memberList property is also a value of the skos:member property.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://www.w3.org/2004/02/skos/core"/>
        <skos:definition xml:lang="en">Relates an ordered collection to the RDF list containing its members.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/2004/02/skos/core#narrowMatch -->


    <owl:ObjectProperty rdf:about="http://www.w3.org/2004/02/skos/core#narrowMatch">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2004/02/skos/core#mappingRelation"/>
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2004/02/skos/core#narrower"/>
        <rdfs:isDefinedBy rdf:resource="http://www.w3.org/2004/02/skos/core"/>
        <skos:definition xml:lang="en">skos:narrowMatch is used to state a hierarchical mapping link between two conceptual resources in different concept schemes.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/2004/02/skos/core#narrower -->


    <owl:ObjectProperty rdf:about="http://www.w3.org/2004/02/skos/core#narrower">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2004/02/skos/core#narrowerTransitive"/>
        <rdfs:comment xml:lang="en">Narrower concepts are typically rendered as children in a concept hierarchy (tree).</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://www.w3.org/2004/02/skos/core"/>
        <skos:definition xml:lang="en">Relates a concept to a concept that is more specific in meaning.</skos:definition>
        <skos:scopeNote xml:lang="en">By convention, skos:broader is only used to assert an immediate (i.e. direct) hierarchical link between two conceptual resources.</skos:scopeNote>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/2004/02/skos/core#narrowerTransitive -->


    <owl:ObjectProperty rdf:about="http://www.w3.org/2004/02/skos/core#narrowerTransitive">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2004/02/skos/core#semanticRelation"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <rdfs:isDefinedBy rdf:resource="http://www.w3.org/2004/02/skos/core"/>
        <skos:definition>skos:narrowerTransitive is a transitive superproperty of skos:narrower.</skos:definition>
        <skos:scopeNote xml:lang="en">By convention, skos:narrowerTransitive is not used to make assertions. Rather, the properties can be used to draw inferences about the transitive closure of the hierarchical relation, which is useful e.g. when implementing a simple query expansion algorithm in a search application.</skos:scopeNote>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/2004/02/skos/core#related -->


    <owl:ObjectProperty rdf:about="http://www.w3.org/2004/02/skos/core#related">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2004/02/skos/core#semanticRelation"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
        <rdfs:comment xml:lang="en">skos:related is disjoint with skos:broaderTransitive</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://www.w3.org/2004/02/skos/core"/>
        <skos:definition xml:lang="en">Relates a concept to a concept with which there is an associative semantic relationship.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/2004/02/skos/core#relatedMatch -->


    <owl:ObjectProperty rdf:about="http://www.w3.org/2004/02/skos/core#relatedMatch">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2004/02/skos/core#mappingRelation"/>
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2004/02/skos/core#related"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
        <rdfs:isDefinedBy rdf:resource="http://www.w3.org/2004/02/skos/core"/>
        <skos:definition xml:lang="en">skos:relatedMatch is used to state an associative mapping link between two conceptual resources in different concept schemes.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/2004/02/skos/core#semanticRelation -->


    <owl:ObjectProperty rdf:about="http://www.w3.org/2004/02/skos/core#semanticRelation">
        <rdfs:domain rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdfs:isDefinedBy rdf:resource="http://www.w3.org/2004/02/skos/core"/>
        <skos:definition xml:lang="en">Links a concept to a concept related by meaning.</skos:definition>
        <skos:scopeNote xml:lang="en">This property should not be used directly, but as a super-property for all properties denoting a relationship of meaning between concepts.</skos:scopeNote>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/2004/02/skos/core#topConceptOf -->


    <owl:ObjectProperty rdf:about="http://www.w3.org/2004/02/skos/core#topConceptOf">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2004/02/skos/core#inScheme"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#ConceptScheme"/>
        <rdfs:isDefinedBy rdf:resource="http://www.w3.org/2004/02/skos/core"/>
        <skos:definition xml:lang="en">Relates a concept to the concept scheme that it is a top level concept of.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Link -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Link">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Audio"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Image"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Narrative"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
        <rdfs:label xml:lang="en">Link</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#format -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#format">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#MegalithicMonument"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="en">format</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#heightMeters -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#heightMeters">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Menhir"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:label xml:lang="en">height Meters</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#rockType -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#rockType">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#MegalithicMonument"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="en">rock Type</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#usagetypeArtefacts -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#usagetypeArtefacts">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#ArchaeologicalArtefact"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="en">usagetype Artefacts</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#usagetypeMegalithism -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#usagetypeMegalithism">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#MegalithicSite"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="en">usagetype Megalithism</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.w3.org/2004/02/skos/core#notation -->


    <owl:DatatypeProperty rdf:about="http://www.w3.org/2004/02/skos/core#notation">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <rdfs:isDefinedBy rdf:resource="http://www.w3.org/2004/02/skos/core"/>
        <skos:definition xml:lang="en">A notation, also known as classification code, is a string of characters such as &quot;T58.5&quot; or &quot;303.4833&quot; used to uniquely identify a concept within the scope of a given concept scheme.</skos:definition>
        <skos:scopeNote xml:lang="en">By convention, skos:notation is used with a typed literal in the object position of the triple.</skos:scopeNote>
    </owl:DatatypeProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#App -->


    <owl:Class rdf:about="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#App">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#E31_Document"/>
        <rdfs:comment>A software application designed to guide or assist users, often in cultural or educational contexts</rdfs:comment>
        <rdfs:label xml:lang="en">App</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#ArchaeologicalArtefact -->


    <owl:Class rdf:about="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#ArchaeologicalArtefact">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#E19_Physical_Object"/>
        <rdfs:comment>Artefacts found in an archaeological site.</rdfs:comment>
        <rdfs:label xml:lang="en">Archaeological Artefact</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#ArchaeologicalMonument -->


    <owl:Class rdf:about="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#ArchaeologicalMonument">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#CulturalHeritageMonument"/>
        <rdfs:comment>A monument that preserves traces of human occupation</rdfs:comment>
        <rdfs:label xml:lang="en">Archaeological Monument</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#ArchaeologicalSite -->


    <owl:Class rdf:about="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#ArchaeologicalSite">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#E27_Site"/>
        <rdfs:comment>The area where traces of human occupation have been found.</rdfs:comment>
        <rdfs:label xml:lang="en">Archaeological Site</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Archaeologist -->


    <owl:Class rdf:about="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Archaeologist">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#E21_Person"/>
        <rdfs:comment>A professional whose expertise involves both on-site and off-site study of past human societies.</rdfs:comment>
        <rdfs:label xml:lang="en">Archaeologist</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Arrowhead -->


    <owl:Class rdf:about="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Arrowhead">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#ArchaeologicalArtefact"/>
        <rdfs:comment>The tip of an arrow.</rdfs:comment>
        <rdfs:label xml:lang="en">Arrowhead</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Artist -->


    <owl:Class rdf:about="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Artist">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#E21_Person"/>
        <rdfs:comment>An individual whose creative work reflects or engages with the heritage site</rdfs:comment>
        <rdfs:label xml:lang="en">Artist</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Audio -->


    <owl:Class rdf:about="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Audio">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#E31_Document"/>
        <rdfs:comment>Audio files</rdfs:comment>
        <rdfs:label xml:lang="en">Audio</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Beaker -->


    <owl:Class rdf:about="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Beaker">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#ArchaeologicalArtefact"/>
        <rdfs:comment>A ceramic drinking or storage vessel typical of Late Neolithic/Bronze Age.</rdfs:comment>
        <rdfs:label xml:lang="en">Beaker</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#BirdSounds -->


    <owl:Class rdf:about="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#BirdSounds">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#NaturalSoundscape"/>
        <rdfs:comment>Sounds of birds chirping.</rdfs:comment>
        <rdfs:label xml:lang="en">Bird Sounds</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#BronzeAge -->


    <owl:Class rdf:about="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#BronzeAge">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#E4_Period"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Neolithic"/>
        <rdfs:comment>A specific and transitional period between prehistory and protohistory</rdfs:comment>
        <rdfs:label xml:lang="en">Bronze Age</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Cave -->


    <owl:Class rdf:about="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Cave">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#NaturalHeritageSite"/>
        <rdfs:comment>A natural underground space typically formed by the weathering of rock.</rdfs:comment>
        <rdfs:label xml:lang="en">Cave</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Climate -->


    <owl:Class rdf:about="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Climate">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#E26_Physical_Feature"/>
        <rdfs:comment>A feature regarding weather conditions.</rdfs:comment>
        <rdfs:label xml:lang="en">Climate</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Construction -->


    <owl:Class rdf:about="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Construction">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#E7_Activity"/>
        <rdfs:comment>The construction of the archaeological site.</rdfs:comment>
        <rdfs:label xml:lang="en">Construction</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Coordinates -->


    <owl:Class rdf:about="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Coordinates">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#E94_Space_Primitive"/>
        <rdfs:comment>A specific location in space</rdfs:comment>
        <rdfs:label xml:lang="en">Coordinates</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#CulturalHeritageMonument -->


    <owl:Class rdf:about="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#CulturalHeritageMonument">
