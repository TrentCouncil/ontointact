        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#E53_Place"/>
        <rdfs:comment>A subdivision of a region that can encompass multiple municipalities within boundaries</rdfs:comment>
        <rdfs:label xml:lang="en">District</rdfs:label>
    </owl:Class>
    


