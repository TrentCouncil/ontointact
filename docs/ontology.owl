        <rdfs:comment>Object made with the purpose of fulfilling a religious / ritualistic / symbolic goal.</rdfs:comment>
        <rdfs:label xml:lang="en">Idol</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/diniz/ontologies/2024/8/untitled-ontology-30#Image -->


